{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:source:ebus:b524:evidence:v1",
  "title": "Closed B524 normalized evidence V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "schema_version", "source_observed_at", "identity", "observations"],
  "properties": {
    "contract": {"const": "helianthus.ebus.b524.evidence.v1"},
    "schema_version": {"const": 1},
    "source_observed_at": {"$ref": "#/$defs/TimestampV1"},
    "identity": {"$ref": "#/$defs/B524IdentityV1"},
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/ObservationV1"}
    }
  },
  "$defs": {
    "TimestampV1": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,8}[1-9])?Z$"
    },
    "AsciiTokenV1": {
      "type": "string",
      "pattern": "^[ -~]+$",
      "maxLength": 128
    },
    "B524IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "target_pseudonym", "opcode", "GG", "II", "RR", "target_address", "source_address", "group_meaning", "instance_gate", "register_category", "unit_scale_source"],
      "properties": {
        "family": {"const": "B524"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "opcode": {"type": "integer", "minimum": 0, "maximum": 255},
        "GG": {"type": "integer", "minimum": 0, "maximum": 255},
        "II": {"type": "integer", "minimum": 0, "maximum": 255},
        "RR": {"type": "integer", "minimum": 0, "maximum": 65535},
        "target_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "source_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "group_meaning": {"$ref": "#/$defs/AsciiTokenV1"},
        "instance_gate": {"$ref": "#/$defs/AsciiTokenV1"},
        "register_category": {"enum": ["STATE", "CONFIG", "PARAMS"]},
        "unit_scale_source": {"$ref": "#/$defs/AsciiTokenV1"}
      }
    },
    "ObservationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "quality"],
      "properties": {
        "value": {"$ref": "#/$defs/AsciiTokenV1"},
        "unit": {"$ref": "#/$defs/AsciiTokenV1"},
        "quality": {"enum": ["OBSERVED", "STALE"]}
      }
    }
  }
}
