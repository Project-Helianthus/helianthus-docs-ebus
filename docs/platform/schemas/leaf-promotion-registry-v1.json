{
  "contract": "helianthus.platform.leaf-promotion-registry.v1",
  "version": 1,
  "gate": "MSP-085",
  "dossier_contract": {
    "contract": "helianthus.platform.leaf-promotion-dossier.v1",
    "schema_version": 1,
    "schema_path": "docs/platform/schemas/leaf-promotion-dossier-v1.schema.json"
  },
  "result_contract": {
    "contract": "helianthus.platform.leaf-promotion-lock-result.v1",
    "schema_version": 1,
    "schema_path": "docs/platform/schemas/leaf-promotion-lock-result-v1.schema.json",
    "replay_tool": "leaf-promotion-replay",
    "replay_version": 1
  },
  "source_contracts": {
    "m7_graph": "helianthus.platform.draft-candidate-fact-graph.v1",
    "m7_replay": "helianthus.platform.draft-candidate-fact-replay.v1",
    "m8_evidence": "helianthus.platform.multi-runtime-coexistence-evidence.v1",
    "m8_report": "helianthus.platform.multi-runtime-coexistence-report.v1"
  },
  "source_artifacts": {
    "m7_graph": "docs/platform/fixtures/candidate-fact-graph/v1/positive/graph.json",
    "m7_replay": "docs/platform/fixtures/candidate-fact-graph/v1/positive/replay-result.json",
    "m8_evidence": "docs/platform/fixtures/coexistence-no-drift/v1/positive/evidence.json",
    "m8_report": "docs/platform/fixtures/coexistence-no-drift/v1/positive/report.json"
  },
  "ebus_source_families": [
    "B509",
    "B524",
    "B555"
  ],
  "b524_namespaces": [
    "OP_0X02",
    "OP_0X06"
  ],
  "terminal_states": [
    "NO_SIGNAL",
    "CLOUD_ONLY",
    "CONFLICT",
    "NOT_TESTED"
  ],
  "terminal_decision": "WITHHELD",
  "terminal_visibility": "RAW_DEBUG_ONLY",
  "promoted_visibility": "LOCKED_NOT_EXPOSED",
  "inheritance_policy": {
    "family": false,
    "device": false,
    "sibling": false
  },
  "comparator_fields": [
    "type",
    "window",
    "tolerance",
    "conversion",
    "rounding",
    "minimum_samples",
    "maximum_missing",
    "stale_cutoff_ns",
    "conflict_threshold",
    "observed_samples",
    "missing_samples",
    "outcome"
  ],
  "required_abort_conditions": [
    "LEASE_EXPIRED",
    "WRITER_CONFLICT",
    "GATEWAY_ROUTER_PATH_LOST",
    "SOURCE_STALE",
    "CONFLICT_THRESHOLD_EXCEEDED",
    "ROLLBACK_FAILED"
  ],
  "required_perturbation_cycles": 3,
  "zero_promotion_consumer_gate": "BLOCKED_ZERO_PROMOTED_LEAVES",
  "current_evidence_policy": "OFF_LAN_OR_SYNTHETIC_CANNOT_PROMOTE",
  "validation_precedence": [
    "json.syntax",
    "schema.dossier",
    "limits.exceeded",
    "registry.binding",
    "identity.native",
    "comparator.invalid",
    "inheritance.forbidden",
    "coexistence.invalid",
    "provenance.binding",
    "mutable.safety",
    "mutable.rollback",
    "state.terminal",
    "evidence.ineligible",
    "hash.replay",
    "consumer.block",
    "hash.dossier"
  ],
  "limits": {
    "max_dossier_bytes": 1048576,
    "max_depth": 32,
    "max_leaves": 64,
    "max_string_bytes": 4096,
    "max_total_members": 16384,
    "max_total_list_items": 8192
  }
}
