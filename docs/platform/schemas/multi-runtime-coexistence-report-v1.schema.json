{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.helianthus.local/schemas/multi-runtime-coexistence-report-v1.schema.json",
  "title": "Helianthus Multi-Runtime Coexistence Report V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schema_version",
    "fixture_id",
    "report_id",
    "report_hash",
    "evidence_id",
    "evidence_hash",
    "gate",
    "verdict",
    "m7_binding",
    "baseline",
    "scenarios",
    "acceptance_matrix",
    "rollback"
  ],
  "properties": {
    "contract": {"const": "helianthus.platform.multi-runtime-coexistence-report.v1"},
    "schema_version": {"const": 1},
    "fixture_id": {"type": "string", "pattern": "^MSP08-G18-[A-Z0-9-]+$", "maxLength": 128},
    "report_id": {"type": "string", "pattern": "^mrcrv1:sha256:[0-9a-f]{64}$"},
    "report_hash": {"$ref": "#/$defs/Digest"},
    "evidence_id": {"type": "string", "pattern": "^mrcv1:sha256:[0-9a-f]{64}$"},
    "evidence_hash": {"$ref": "#/$defs/Digest"},
    "gate": {"const": "EEBUS-G18"},
    "verdict": {"const": "PASS"},
    "m7_binding": {"$ref": "#/$defs/M7Binding"},
    "baseline": {"$ref": "#/$defs/Baseline"},
    "scenarios": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/Scenario"}
    },
    "acceptance_matrix": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {"$ref": "#/$defs/AcceptanceRow"}
    },
    "rollback": {"$ref": "#/$defs/Rollback"}
  },
  "$defs": {
    "Digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "M7Binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completion_token", "docs_source_commit", "graph_id", "graph_hash", "replay_id", "replay_hash"],
      "properties": {
        "completion_token": {"type": "string", "maxLength": 128},
        "docs_source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "graph_id": {"type": "string", "pattern": "^dcfgv1:sha256:[0-9a-f]{64}$"},
        "graph_hash": {"$ref": "#/$defs/Digest"},
        "replay_id": {"type": "string", "pattern": "^dcfrv1:sha256:[0-9a-f]{64}$"},
        "replay_hash": {"$ref": "#/$defs/Digest"}
      }
    },
    "ViewHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_id", "shape_hash", "canonical_payload_hash"],
      "properties": {
        "view_id": {"type": "string", "maxLength": 256},
        "shape_hash": {"$ref": "#/$defs/Digest"},
        "canonical_payload_hash": {"$ref": "#/$defs/Digest"}
      }
    },
    "Baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "state", "source_commit", "artifact_digest", "view_hashes"],
      "properties": {
        "run_id": {"type": "string", "pattern": "^msp08-run-[0-9]{2}$"},
        "state": {"const": "EEBUS_DISABLED_BASELINE"},
        "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "artifact_digest": {"$ref": "#/$defs/Digest"},
        "view_hashes": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"$ref": "#/$defs/ViewHash"}}
      }
    },
    "Scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "state", "result", "checks", "view_hashes"],
      "properties": {
        "run_id": {"type": "string", "pattern": "^msp08-run-[0-9]{2}$"},
        "state": {"enum": ["EEBUS_DISABLED_CONFIRMED", "EEBUS_ENABLED_NO_SERVICES", "EEBUS_CONNECTED_CANDIDATE_ONLY", "EEBUS_CONFLICTED_WITHHELD", "EEBUS_DISABLED_ROLLBACK"]},
        "result": {"enum": ["NO_DRIFT", "EXPECTED_NO_SERVICES_NO_DRIFT", "CANDIDATE_CONFINED_NO_DRIFT", "CONFLICT_WITHHELD_NO_DRIFT", "ROLLBACK_EXACT_BASELINE"]},
        "checks": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"type": "string", "maxLength": 128}},
        "view_hashes": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"$ref": "#/$defs/ViewHash"}}
      }
    },
    "AcceptanceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "required_checks", "passed"],
      "properties": {
        "state": {"type": "string", "maxLength": 128},
        "required_checks": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"type": "string", "maxLength": 128}},
        "passed": {"const": true}
      }
    },
    "Rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "runtime_disabled", "candidate_graph_disabled", "exact_baseline_restored"],
      "properties": {
        "run_id": {"type": "string", "pattern": "^msp08-run-[0-9]{2}$"},
        "runtime_disabled": {"const": true},
        "candidate_graph_disabled": {"const": true},
        "exact_baseline_restored": {"const": true}
      }
    }
  }
}
