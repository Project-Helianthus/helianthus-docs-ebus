{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.helianthus.local/schemas/leaf-promotion-lock-result-v1.schema.json",
  "title": "Helianthus Leaf Promotion Lock Result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schema_version",
    "dossier_id",
    "dossier_hash",
    "replay_tool",
    "replay_version",
    "counts",
    "leaves",
    "m9_consumer_gate",
    "verdict",
    "result_hash"
  ],
  "properties": {
    "contract": {
      "const": "helianthus.platform.leaf-promotion-lock-result.v1"
    },
    "schema_version": {
      "const": 1
    },
    "dossier_id": {
      "$ref": "#/$defs/TokenV1"
    },
    "dossier_hash": {
      "$ref": "#/$defs/DigestV1"
    },
    "replay_tool": {
      "const": "leaf-promotion-replay"
    },
    "replay_version": {
      "const": 1
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "promoted",
        "withheld"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "promoted": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        },
        "withheld": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        }
      }
    },
    "leaves": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "leaf_id",
          "semantic_path",
          "decision",
          "terminal_state",
          "visibility"
        ],
        "properties": {
          "leaf_id": {
            "$ref": "#/$defs/TokenV1"
          },
          "semantic_path": {
            "type": "string",
            "minLength": 2,
            "maxLength": 512,
            "pattern": "^/[a-z0-9_]+(?:/[a-z0-9_]+)*$"
          },
          "decision": {
            "enum": [
              "PROMOTED",
              "WITHHELD"
            ]
          },
          "terminal_state": {
            "oneOf": [
              {
                "enum": [
                  "NO_SIGNAL",
                  "CLOUD_ONLY",
                  "CONFLICT",
                  "NOT_TESTED"
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "visibility": {
            "enum": [
              "RAW_DEBUG_ONLY",
              "LOCKED_NOT_EXPOSED"
            ]
          }
        }
      }
    },
    "m9_consumer_gate": {
      "enum": [
        "BLOCKED_ZERO_PROMOTED_LEAVES",
        "READY_FOR_M9"
      ]
    },
    "verdict": {
      "enum": [
        "VALID_ZERO_PROMOTION",
        "VALID_PROMOTION_LOCK"
      ]
    },
    "result_hash": {
      "$ref": "#/$defs/DigestV1"
    }
  },
  "$defs": {
    "TokenV1": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[\\x20-\\x7e]+$"
    },
    "DigestV1": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
