{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:source:ebus:b555:evidence:v1",
  "title": "Closed B555 normalized evidence V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "schema_version", "source_observed_at", "identity", "observations"],
  "properties": {
    "contract": {"const": "helianthus.ebus.b555.evidence.v1"},
    "schema_version": {"const": 1},
    "source_observed_at": {"$ref": "#/$defs/TimestampV1"},
    "identity": {"$ref": "#/$defs/B555IdentityV1"},
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/ObservationV1"}
    }
  },
  "$defs": {
    "TimestampV1": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,8}[1-9])?Z$"
    },
    "AsciiTokenV1": {
      "type": "string",
      "pattern": "^[ -~]+$",
      "maxLength": 128
    },
    "B555IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "target_pseudonym", "device_family", "schedule_program", "slot_index", "day_of_week", "time_identity", "operation_mode_context", "unit_scale_source"],
      "properties": {
        "family": {"const": "B555"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "device_family": {"$ref": "#/$defs/AsciiTokenV1"},
        "schedule_program": {"$ref": "#/$defs/AsciiTokenV1"},
        "slot_index": {"type": "integer", "minimum": 0, "maximum": 255},
        "day_of_week": {"enum": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"]},
        "time_identity": {"type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"},
        "operation_mode_context": {"$ref": "#/$defs/AsciiTokenV1"},
        "unit_scale_source": {"$ref": "#/$defs/AsciiTokenV1"}
      }
    },
    "ObservationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "quality"],
      "properties": {
        "value": {"$ref": "#/$defs/AsciiTokenV1"},
        "quality": {"enum": ["OBSERVED", "STALE"]}
      }
    }
  }
}
