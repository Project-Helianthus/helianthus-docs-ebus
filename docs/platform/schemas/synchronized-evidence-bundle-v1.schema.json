{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:platform:synchronized-evidence-bundle:v1",
  "title": "SynchronizedEvidenceBundleV1",
  "$ref": "#/$defs/SynchronizedEvidenceBundleV1",
  "$defs": {
    "SafeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "Byte": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "Word": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "TimestampV1": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{0,8}[1-9])?Z$"
    },
    "DigestV1": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "SchemaDigestV1": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "GitCommitV1": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "VersionV1": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\+git\\.[0-9a-f]{40}$"
    },
    "PlatformPseudonymV1": {
      "type": "string",
      "pattern": "^(ebus|eebus|cloud|target|marker|remask)-[0-9a-f]{32}$"
    },
    "RepositoryV1": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "maxLength": 256
    },
    "RepositoryPathV1": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-][A-Za-z0-9._-]*(/[A-Za-z0-9_-][A-Za-z0-9._-]*)*$",
      "maxLength": 1024
    },
    "AsciiTokenV1": {
      "type": "string",
      "pattern": "^[ -~]+$",
      "maxLength": 128
    },
    "AuthScopeV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "permissions"],
      "properties": {
        "authority": {"const": "effective"},
        "permissions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/AsciiTokenV1"}
        }
      }
    },
    "EvidenceRefV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "digest_algorithm",
        "digest",
        "repository",
        "commit",
        "path"
      ],
      "properties": {
        "kind": {"enum": ["CONTENT", "GIT_BLOB"]},
        "digest_algorithm": {
          "enum": ["SHA256_CONTENT_BYTES", "SHA256_GIT_BLOB_V1"]
        },
        "digest": {"$ref": "#/$defs/DigestV1"},
        "repository": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/RepositoryV1"}
          ]
        },
        "commit": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/GitCommitV1"}
          ]
        },
        "path": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/RepositoryPathV1"}
          ]
        }
      },
      "oneOf": [
        {
          "properties": {
            "kind": {"const": "CONTENT"},
            "digest_algorithm": {"const": "SHA256_CONTENT_BYTES"},
            "repository": {"type": "null"},
            "commit": {"type": "null"},
            "path": {"type": "null"}
          }
        },
        {
          "properties": {
            "kind": {"const": "GIT_BLOB"},
            "digest_algorithm": {"const": "SHA256_GIT_BLOB_V1"},
            "repository": {"$ref": "#/$defs/RepositoryV1"},
            "commit": {"$ref": "#/$defs/GitCommitV1"},
            "path": {"$ref": "#/$defs/RepositoryPathV1"}
          }
        }
      ]
    },
    "WindowSegmentV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_offset_ns", "end_offset_ns"],
      "properties": {
        "start_offset_ns": {"$ref": "#/$defs/SafeInteger"},
        "end_offset_ns": {"$ref": "#/$defs/SafeInteger"}
      }
    },
    "ActionWindowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_offset_ns",
        "marker_offset_ns",
        "marker_captured_at",
        "marker_id",
        "evidence_ref",
        "end_offset_ns"
      ],
      "properties": {
        "start_offset_ns": {"$ref": "#/$defs/SafeInteger"},
        "marker_offset_ns": {"$ref": "#/$defs/SafeInteger"},
        "marker_captured_at": {"$ref": "#/$defs/TimestampV1"},
        "marker_id": {
          "type": "string",
          "pattern": "^marker-[0-9a-f]{32}$"
        },
        "evidence_ref": {"$ref": "#/$defs/EvidenceRefV1"},
        "end_offset_ns": {"$ref": "#/$defs/SafeInteger"}
      }
    },
    "CaptureWindowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pre", "action", "post"],
      "properties": {
        "pre": {"$ref": "#/$defs/WindowSegmentV1"},
        "action": {"$ref": "#/$defs/ActionWindowV1"},
        "post": {"$ref": "#/$defs/WindowSegmentV1"}
      }
    },
    "ClockObservationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "offset_ns", "uncertainty_ns"],
      "properties": {
        "observed_at": {"$ref": "#/$defs/TimestampV1"},
        "offset_ns": {"$ref": "#/$defs/SafeInteger"},
        "uncertainty_ns": {"$ref": "#/$defs/SafeInteger"}
      }
    },
    "CaptureClockV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clock_id",
        "wall_anchor",
        "monotonic_anchor_ns",
        "captured_offset_ns",
        "resolution_ns",
        "maximum_skew_ns",
        "observations"
      ],
      "properties": {
        "clock_id": {"const": "capture-clock-1"},
        "wall_anchor": {"$ref": "#/$defs/TimestampV1"},
        "monotonic_anchor_ns": {"const": 0},
        "captured_offset_ns": {"$ref": "#/$defs/SafeInteger"},
        "resolution_ns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "maximum_skew_ns": {"$ref": "#/$defs/SafeInteger"},
        "observations": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/ClockObservationV1"}
        }
      }
    },
    "CaptureScopeV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose", "source_kinds", "phases"],
      "properties": {
        "purpose": {"const": "SYNCHRONIZED_EVIDENCE_ONLY"},
        "source_kinds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]}
        },
        "phases": {
          "const": ["pre", "action", "post"]
        }
      }
    },
    "CaptureLimitsV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_sources",
        "max_items_per_source",
        "max_artifact_bytes",
        "max_bundle_bytes",
        "max_depth",
        "max_string_bytes",
        "max_capture_duration_ns",
        "max_source_duration_ns"
      ],
      "properties": {
        "max_sources": {"type": "integer", "minimum": 1, "maximum": 64},
        "max_items_per_source": {"type": "integer", "minimum": 1, "maximum": 4096},
        "max_artifact_bytes": {"type": "integer", "minimum": 1, "maximum": 1048576},
        "max_bundle_bytes": {"type": "integer", "minimum": 1, "maximum": 67108864},
        "max_depth": {"type": "integer", "minimum": 1, "maximum": 32},
        "max_string_bytes": {"type": "integer", "minimum": 1, "maximum": 65536},
        "max_capture_duration_ns": {"type": "integer", "minimum": 1, "maximum": 900000000000},
        "max_source_duration_ns": {"type": "integer", "minimum": 1, "maximum": 60000000000}
      }
    },
    "B509IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "target_pseudonym",
        "target_address",
        "target_product",
        "register_family",
        "register_id",
        "unit_scale_source",
        "evidence_role"
      ],
      "properties": {
        "family": {"const": "B509"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "target_address": {"$ref": "#/$defs/Byte"},
        "target_product": {"$ref": "#/$defs/AsciiTokenV1"},
        "register_family": {"$ref": "#/$defs/AsciiTokenV1"},
        "register_id": {"$ref": "#/$defs/Word"},
        "unit_scale_source": {"$ref": "#/$defs/AsciiTokenV1"},
        "evidence_role": {"enum": ["AUTHORITATIVE", "MIRROR", "FALLBACK"]}
      }
    },
    "B524IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "target_pseudonym",
        "opcode",
        "GG",
        "II",
        "RR",
        "target_address",
        "source_address",
        "group_meaning",
        "instance_gate",
        "register_category",
        "unit_scale_source"
      ],
      "properties": {
        "family": {"const": "B524"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "opcode": {"$ref": "#/$defs/Byte"},
        "GG": {"$ref": "#/$defs/Byte"},
        "II": {"$ref": "#/$defs/Byte"},
        "RR": {"$ref": "#/$defs/Word"},
        "target_address": {"$ref": "#/$defs/Byte"},
        "source_address": {"$ref": "#/$defs/Byte"},
        "group_meaning": {"$ref": "#/$defs/AsciiTokenV1"},
        "instance_gate": {"$ref": "#/$defs/AsciiTokenV1"},
        "register_category": {"enum": ["STATE", "CONFIG", "PARAMS"]},
        "unit_scale_source": {"$ref": "#/$defs/AsciiTokenV1"}
      }
    },
    "B555IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "target_pseudonym",
        "device_family",
        "schedule_program",
        "slot_index",
        "day_of_week",
        "time_identity",
        "operation_mode_context",
        "unit_scale_source"
      ],
      "properties": {
        "family": {"const": "B555"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "device_family": {"$ref": "#/$defs/AsciiTokenV1"},
        "schedule_program": {"$ref": "#/$defs/AsciiTokenV1"},
        "slot_index": {"$ref": "#/$defs/Byte"},
        "day_of_week": {"enum": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"]},
        "time_identity": {"type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"},
        "operation_mode_context": {"$ref": "#/$defs/AsciiTokenV1"},
        "unit_scale_source": {"$ref": "#/$defs/AsciiTokenV1"}
      }
    },
    "EBusSourceIdentityV1": {
      "oneOf": [
        {"$ref": "#/$defs/B509IdentityV1"},
        {"$ref": "#/$defs/B524IdentityV1"},
        {"$ref": "#/$defs/B555IdentityV1"}
      ]
    },
    "RequestScopeV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "source_kind", "operation_scope"],
      "properties": {
        "phase": {"enum": ["pre", "action", "post"]},
        "source_kind": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]},
        "operation_scope": {"$ref": "#/$defs/AsciiTokenV1"}
      }
    },
    "SnapshotScopeV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "selector"],
      "properties": {
        "mode": {"enum": ["SNAPSHOT", "LIVE_READ", "PRECAPTURED"]},
        "selector": {"$ref": "#/$defs/AsciiTokenV1"}
      }
    },
    "SourceBindingV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_kind",
        "runtime_pseudonym",
        "operation_id",
        "operation_version",
        "request_scope",
        "snapshot_scope",
        "source_kind",
        "source_contract",
        "source_schema_version",
        "owner_repository",
        "owner_path",
        "owner_commit",
        "schema_sha256",
        "capture_window",
        "mask_tier",
        "auth_scope",
        "ebus_identity"
      ],
      "properties": {
        "runtime_kind": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]},
        "runtime_pseudonym": {"type": "string", "pattern": "^runtime-[0-9a-f]{32}$"},
        "operation_id": {"$ref": "#/$defs/AsciiTokenV1"},
        "operation_version": {"type": "string", "pattern": "^git:[0-9a-f]{40}$"},
        "request_scope": {"$ref": "#/$defs/RequestScopeV1"},
        "snapshot_scope": {"$ref": "#/$defs/SnapshotScopeV1"},
        "source_kind": {"enum": ["EBUS_B509", "EBUS_B524", "EBUS_B555", "EEBUS", "CLOUD_APP"]},
        "source_contract": {"$ref": "#/$defs/AsciiTokenV1"},
        "source_schema_version": {"$ref": "#/$defs/SafeInteger"},
        "owner_repository": {"$ref": "#/$defs/RepositoryV1"},
        "owner_path": {"$ref": "#/$defs/RepositoryPathV1"},
        "owner_commit": {"$ref": "#/$defs/GitCommitV1"},
        "schema_sha256": {"$ref": "#/$defs/SchemaDigestV1"},
        "capture_window": {"$ref": "#/$defs/CaptureWindowV1"},
        "mask_tier": {"const": "redacted"},
        "auth_scope": {"$ref": "#/$defs/AuthScopeV1"},
        "ebus_identity": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/EBusSourceIdentityV1"}
          ]
        }
      }
    },
    "RemaskedPseudonymV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "pseudonym"],
      "properties": {
        "path": {"type": "string", "pattern": "^/(?:[^~/]|~0|~1)+(?:/(?:[^~/]|~0|~1)+)*$", "maxLength": 1024},
        "pseudonym": {"type": "string", "pattern": "^[A-Za-z0-9_-]{43}$"}
      }
    },
    "RemaskingV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "scope_id", "entries"],
      "properties": {
        "method": {"const": "PER_BUNDLE_CSPRNG"},
        "scope_id": {"type": "string", "pattern": "^remask-[0-9a-f]{32}$"},
        "entries": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/RemaskedPseudonymV1"}
        }
      }
    },
    "NullableTimestampV1": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/TimestampV1"}
      ]
    },
    "NullableIntegerV1": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/SafeInteger"}
      ]
    },
    "SourceRecordV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "schema_version",
        "source_id",
        "source_kind",
        "phase",
        "state",
        "error_category",
        "source_contract",
        "source_schema_version",
        "source_binding",
        "capture_window",
        "clock",
        "scope",
        "mask_tier",
        "auth_scope",
        "evidence_refs",
        "recorder_version",
        "replay_version",
        "acquisition_started_at",
        "acquisition_ended_at",
        "acquisition_start_offset_ns",
        "acquisition_end_offset_ns",
        "measured_latency_ns",
        "maximum_skew_ns",
        "ebus_identity",
        "artifact_ids"
      ],
      "properties": {
        "contract": {"const": "helianthus.platform.synchronized-evidence-bundle.v1"},
        "schema_version": {"const": 1},
        "source_id": {"type": "string", "pattern": "^(ebus|eebus|cloud)-[0-9a-f]{32}$"},
        "source_kind": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]},
        "phase": {"enum": ["pre", "action", "post"]},
        "state": {"enum": ["PRESENT", "WITHHELD", "NOT_TESTED", "UNAVAILABLE"]},
        "error_category": {
          "oneOf": [
            {"type": "null"},
            {"enum": ["POLICY_WITHHELD", "AUTHORIZATION_DENIED", "REDACTION_FAILED", "EXACT_IDENTITY_MISSING", "NOT_SELECTED", "BUDGET_EXHAUSTED", "BACKEND_UNAVAILABLE", "TIMEOUT", "ACQUISITION_FAILED"]}
          ]
        },
        "source_contract": {"$ref": "#/$defs/AsciiTokenV1"},
        "source_schema_version": {"$ref": "#/$defs/SafeInteger"},
        "source_binding": {"$ref": "#/$defs/SourceBindingV1"},
        "capture_window": {"$ref": "#/$defs/CaptureWindowV1"},
        "clock": {"$ref": "#/$defs/CaptureClockV1"},
        "scope": {"$ref": "#/$defs/CaptureScopeV1"},
        "mask_tier": {"const": "redacted"},
        "auth_scope": {"$ref": "#/$defs/AuthScopeV1"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/EvidenceRefV1"}},
        "recorder_version": {"$ref": "#/$defs/VersionV1"},
        "replay_version": {"$ref": "#/$defs/VersionV1"},
        "acquisition_started_at": {"$ref": "#/$defs/NullableTimestampV1"},
        "acquisition_ended_at": {"$ref": "#/$defs/NullableTimestampV1"},
        "acquisition_start_offset_ns": {"$ref": "#/$defs/NullableIntegerV1"},
        "acquisition_end_offset_ns": {"$ref": "#/$defs/NullableIntegerV1"},
        "measured_latency_ns": {"$ref": "#/$defs/NullableIntegerV1"},
        "maximum_skew_ns": {"$ref": "#/$defs/SafeInteger"},
        "ebus_identity": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/EBusSourceIdentityV1"}
          ]
        },
        "artifact_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^seav1:sha256:[0-9a-f]{64}$"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"state": {"const": "PRESENT"}}},
          "then": {
            "properties": {
              "error_category": {"type": "null"},
              "artifact_ids": {"minItems": 1},
              "acquisition_started_at": {"$ref": "#/$defs/TimestampV1"},
              "acquisition_ended_at": {"$ref": "#/$defs/TimestampV1"},
              "acquisition_start_offset_ns": {"$ref": "#/$defs/SafeInteger"},
              "acquisition_end_offset_ns": {"$ref": "#/$defs/SafeInteger"},
              "measured_latency_ns": {"$ref": "#/$defs/SafeInteger"}
            }
          }
        },
        {
          "if": {"properties": {"state": {"const": "NOT_TESTED"}}},
          "then": {
            "properties": {
              "error_category": {"enum": ["NOT_SELECTED", "BUDGET_EXHAUSTED", "EXACT_IDENTITY_MISSING"]},
              "artifact_ids": {"maxItems": 0},
              "acquisition_started_at": {"type": "null"},
              "acquisition_ended_at": {"type": "null"},
              "acquisition_start_offset_ns": {"type": "null"},
              "acquisition_end_offset_ns": {"type": "null"},
              "measured_latency_ns": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"state": {"const": "UNAVAILABLE"}}},
          "then": {
            "properties": {
              "error_category": {"enum": ["BACKEND_UNAVAILABLE", "TIMEOUT", "ACQUISITION_FAILED"]},
              "artifact_ids": {"maxItems": 0},
              "acquisition_started_at": {"$ref": "#/$defs/TimestampV1"},
              "acquisition_ended_at": {"$ref": "#/$defs/TimestampV1"},
              "acquisition_start_offset_ns": {"$ref": "#/$defs/SafeInteger"},
              "acquisition_end_offset_ns": {"$ref": "#/$defs/SafeInteger"},
              "measured_latency_ns": {"$ref": "#/$defs/SafeInteger"}
            }
          }
        },
        {
          "if": {"properties": {"state": {"const": "WITHHELD"}}},
          "then": {
            "properties": {
              "error_category": {"enum": ["POLICY_WITHHELD", "AUTHORIZATION_DENIED", "REDACTION_FAILED", "EXACT_IDENTITY_MISSING"]},
              "artifact_ids": {"maxItems": 0}
            }
          }
        }
      ]
    },
    "SourceArtifactV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "schema_version",
        "artifact_id",
        "source_id",
        "source_kind",
        "phase",
        "source_contract",
        "source_schema_version",
        "source_binding",
        "ebus_identity",
        "source_observed_at",
        "recorder_ingested_at",
        "recorder_ingested_offset_ns",
        "capture_window",
        "clock",
        "scope",
        "mask_tier",
        "auth_scope",
        "evidence_refs",
        "recorder_version",
        "replay_version",
        "remasking",
        "item_count",
        "byte_count",
        "normalized_evidence",
        "redacted_hash"
      ],
      "properties": {
        "contract": {"const": "helianthus.platform.synchronized-evidence-bundle.v1"},
        "schema_version": {"const": 1},
        "artifact_id": {"type": "string", "pattern": "^seav1:sha256:[0-9a-f]{64}$"},
        "source_id": {"type": "string", "pattern": "^(ebus|eebus|cloud)-[0-9a-f]{32}$"},
        "source_kind": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]},
        "phase": {"enum": ["pre", "action", "post"]},
        "source_contract": {"$ref": "#/$defs/AsciiTokenV1"},
        "source_schema_version": {"$ref": "#/$defs/SafeInteger"},
        "source_binding": {"$ref": "#/$defs/SourceBindingV1"},
        "ebus_identity": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/EBusSourceIdentityV1"}
          ]
        },
        "source_observed_at": {"$ref": "#/$defs/TimestampV1"},
        "recorder_ingested_at": {"$ref": "#/$defs/TimestampV1"},
        "recorder_ingested_offset_ns": {"$ref": "#/$defs/SafeInteger"},
        "capture_window": {"$ref": "#/$defs/CaptureWindowV1"},
        "clock": {"$ref": "#/$defs/CaptureClockV1"},
        "scope": {"$ref": "#/$defs/CaptureScopeV1"},
        "mask_tier": {"const": "redacted"},
        "auth_scope": {"$ref": "#/$defs/AuthScopeV1"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/EvidenceRefV1"}},
        "recorder_version": {"$ref": "#/$defs/VersionV1"},
        "replay_version": {"$ref": "#/$defs/VersionV1"},
        "remasking": {"$ref": "#/$defs/RemaskingV1"},
        "item_count": {"$ref": "#/$defs/SafeInteger"},
        "byte_count": {"$ref": "#/$defs/SafeInteger"},
        "normalized_evidence": {},
        "redacted_hash": {"$ref": "#/$defs/DigestV1"}
      }
    },
    "SynchronizedEvidenceBundleV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "schema_version",
        "bundle_id",
        "captured_at",
        "capture_window",
        "clock",
        "scope",
        "mask_tier",
        "auth_scope",
        "limits",
        "evidence_refs",
        "sources",
        "artifacts",
        "recorder_version",
        "replay_version",
        "bundle_hash"
      ],
      "properties": {
        "contract": {"const": "helianthus.platform.synchronized-evidence-bundle.v1"},
        "schema_version": {"const": 1},
        "bundle_id": {"type": "string", "pattern": "^sebv1:sha256:[0-9a-f]{64}$"},
        "captured_at": {"$ref": "#/$defs/TimestampV1"},
        "capture_window": {"$ref": "#/$defs/CaptureWindowV1"},
        "clock": {"$ref": "#/$defs/CaptureClockV1"},
        "scope": {"$ref": "#/$defs/CaptureScopeV1"},
        "mask_tier": {"const": "redacted"},
        "auth_scope": {"$ref": "#/$defs/AuthScopeV1"},
        "limits": {"$ref": "#/$defs/CaptureLimitsV1"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/EvidenceRefV1"}},
        "sources": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/SourceRecordV1"}},
        "artifacts": {"type": "array", "items": {"$ref": "#/$defs/SourceArtifactV1"}},
        "recorder_version": {"$ref": "#/$defs/VersionV1"},
        "replay_version": {"$ref": "#/$defs/VersionV1"},
        "bundle_hash": {"$ref": "#/$defs/DigestV1"}
      }
    }
  }
}
