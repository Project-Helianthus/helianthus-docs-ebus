{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:source:cloud-app:evidence:v1",
  "title": "Closed pre-captured cloud/app input V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "schema_version", "source_observed_at", "subject_pseudonym", "observation_type", "value", "unit"],
  "properties": {
    "contract": {"const": "helianthus.cloud-app.precaptured.evidence.v1"},
    "schema_version": {"const": 1},
    "source_observed_at": {"$ref": "#/$defs/TimestampV1"},
    "subject_pseudonym": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{43}$"
    },
    "observation_type": {
      "enum": ["ROOM_TEMPERATURE", "TARGET_TEMPERATURE", "OPERATING_MODE", "DHW_STATE"]
    },
    "value": {
      "type": "string",
      "pattern": "^[ -~]+$",
      "maxLength": 128
    },
    "unit": {
      "type": "string",
      "pattern": "^[ -~]+$",
      "maxLength": 32
    }
  },
  "$defs": {
    "TimestampV1": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,8}[1-9])?Z$"
    }
  }
}
