{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:platform:draft-candidate-fact-graph:v1",
  "title": "Helianthus closed M7 draft candidate fact graph V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schema_version",
    "graph_id",
    "graph_hash",
    "registry",
    "source_bundle",
    "visibility",
    "limits",
    "comparator_drafts",
    "facts"
  ],
  "properties": {
    "contract": {
      "const": "helianthus.platform.draft-candidate-fact-graph.v1"
    },
    "schema_version": {
      "const": 1
    },
    "graph_id": {
      "type": "string",
      "pattern": "^dcfgv1:sha256:[0-9a-f]{64}$"
    },
    "graph_hash": {
      "$ref": "#/$defs/DigestV1"
    },
    "registry": {
      "$ref": "#/$defs/RegistryBindingV1"
    },
    "source_bundle": {
      "$ref": "#/$defs/SourceBundleV1"
    },
    "visibility": {
      "$ref": "#/$defs/VisibilityV1"
    },
    "limits": {
      "$ref": "#/$defs/LimitsV1"
    },
    "comparator_drafts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/ComparatorDraftV1"
      }
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/FactV1"
      }
    }
  },
  "$defs": {
    "DigestV1": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "TokenV1": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[ -~]+$"
    },
    "NullableTokenV1": {
      "oneOf": [
        {
          "$ref": "#/$defs/TokenV1"
        },
        {
          "type": "null"
        }
      ]
    },
    "DecimalV1": {
      "type": "string",
      "pattern": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$",
      "maxLength": 64
    },
    "EvidenceRefV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "digest_algorithm",
        "digest",
        "repository",
        "commit",
        "path"
      ],
      "properties": {
        "kind": {
          "enum": [
            "CONTENT",
            "GIT_BLOB"
          ]
        },
        "digest_algorithm": {
          "enum": [
            "SHA256_CONTENT_BYTES",
            "SHA256_GIT_BLOB_V1"
          ]
        },
        "digest": {
          "$ref": "#/$defs/DigestV1"
        },
        "repository": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "commit": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "path": {
          "$ref": "#/$defs/NullableTokenV1"
        }
      }
    },
    "RegistryBindingV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "version",
        "digest"
      ],
      "properties": {
        "contract": {
          "const": "helianthus.platform.draft-candidate-fact-registry.v1"
        },
        "version": {
          "const": 1
        },
        "digest": {
          "$ref": "#/$defs/DigestV1"
        }
      }
    },
    "SourceBundleV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "schema_version",
        "bundle_id",
        "bundle_hash",
        "replay_hash",
        "evidence_refs"
      ],
      "properties": {
        "contract": {
          "const": "helianthus.platform.synchronized-evidence-bundle.v1"
        },
        "schema_version": {
          "const": 1
        },
        "bundle_id": {
          "type": "string",
          "pattern": "^sebv1:sha256:[0-9a-f]{64}$"
        },
        "bundle_hash": {
          "$ref": "#/$defs/DigestV1"
        },
        "replay_hash": {
          "$ref": "#/$defs/DigestV1"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/EvidenceRefV1"
          }
        }
      }
    },
    "VisibilityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "promotion_state",
        "stable_exposure",
        "command_capable",
        "protocol_translation"
      ],
      "properties": {
        "channel": {
          "const": "CANDIDATE_DEBUG_REPLAY"
        },
        "promotion_state": {
          "const": "NOT_PROMOTED"
        },
        "stable_exposure": {
          "const": false
        },
        "command_capable": {
          "const": false
        },
        "protocol_translation": {
          "const": false
        }
      }
    },
    "LimitsV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_graph_bytes",
        "max_depth",
        "max_facts",
        "max_evidence_refs_per_fact",
        "max_samples_per_comparator",
        "max_string_bytes",
        "max_path_segments"
      ],
      "properties": {
        "max_graph_bytes": {
          "const": 1048576
        },
        "max_depth": {
          "const": 32
        },
        "max_facts": {
          "const": 64
        },
        "max_evidence_refs_per_fact": {
          "const": 16
        },
        "max_samples_per_comparator": {
          "const": 1024
        },
        "max_string_bytes": {
          "const": 4096
        },
        "max_path_segments": {
          "const": 32
        }
      }
    },
    "ComparatorDraftV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draft_id",
        "type",
        "parameters"
      ],
      "properties": {
        "draft_id": {
          "const": "NUMERIC_WINDOW_V1_DRAFT"
        },
        "type": {
          "const": "NUMERIC_WINDOW"
        },
        "parameters": {
          "$ref": "#/$defs/ComparatorParametersV1"
        }
      }
    },
    "ComparatorParametersV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window",
        "tolerance",
        "unit_conversion",
        "rounding",
        "minimum_samples",
        "maximum_missing_samples",
        "stale_cutoff_ns",
        "conflict_threshold"
      ],
      "properties": {
        "window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start_offset_ns",
            "end_offset_ns"
          ],
          "properties": {
            "start_offset_ns": {
              "type": "integer",
              "minimum": 0
            },
            "end_offset_ns": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "tolerance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "absolute_decimal",
            "relative_ppm"
          ],
          "properties": {
            "absolute_decimal": {
              "$ref": "#/$defs/DecimalV1"
            },
            "relative_ppm": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "unit_conversion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "source_unit",
            "target_unit",
            "scale_decimal",
            "offset_decimal"
          ],
          "properties": {
            "mode": {
              "enum": [
                "IDENTITY",
                "AFFINE"
              ]
            },
            "source_unit": {
              "$ref": "#/$defs/TokenV1"
            },
            "target_unit": {
              "$ref": "#/$defs/TokenV1"
            },
            "scale_decimal": {
              "$ref": "#/$defs/DecimalV1"
            },
            "offset_decimal": {
              "$ref": "#/$defs/DecimalV1"
            }
          }
        },
        "rounding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "decimal_places"
          ],
          "properties": {
            "mode": {
              "enum": [
                "NONE",
                "HALF_EVEN"
              ]
            },
            "decimal_places": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        "minimum_samples": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_missing_samples": {
          "type": "integer",
          "minimum": 0
        },
        "stale_cutoff_ns": {
          "type": "integer",
          "minimum": 1
        },
        "conflict_threshold": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "absolute_decimal",
            "consecutive_samples"
          ],
          "properties": {
            "absolute_decimal": {
              "$ref": "#/$defs/DecimalV1"
            },
            "consecutive_samples": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "ConfidenceV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "basis",
        "score_milli"
      ],
      "properties": {
        "level": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "basis": {
          "enum": [
            "OBSERVED",
            "INFERRED",
            "INSUFFICIENT"
          ]
        },
        "score_milli": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        }
      }
    },
    "B509IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "target_pseudonym",
        "target_address",
        "target_product",
        "register_family",
        "register_id",
        "unit_scale_source",
        "evidence_role"
      ],
      "properties": {
        "family": {
          "const": "B509"
        },
        "target_pseudonym": {
          "$ref": "#/$defs/TokenV1"
        },
        "target_address": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "target_product": {
          "$ref": "#/$defs/TokenV1"
        },
        "register_family": {
          "$ref": "#/$defs/TokenV1"
        },
        "register_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "unit_scale_source": {
          "$ref": "#/$defs/TokenV1"
        },
        "evidence_role": {
          "enum": [
            "AUTHORITATIVE",
            "MIRROR",
            "FALLBACK"
          ]
        }
      }
    },
    "B524IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "target_pseudonym",
        "opcode",
        "GG",
        "II",
        "RR",
        "target_address",
        "source_address",
        "group_meaning",
        "instance_gate",
        "register_category",
        "unit_scale_source"
      ],
      "properties": {
        "family": {
          "const": "B524"
        },
        "target_pseudonym": {
          "$ref": "#/$defs/TokenV1"
        },
        "opcode": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "GG": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "II": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "RR": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "target_address": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "source_address": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "group_meaning": {
          "$ref": "#/$defs/TokenV1"
        },
        "instance_gate": {
          "$ref": "#/$defs/TokenV1"
        },
        "register_category": {
          "enum": [
            "STATE",
            "CONFIG",
            "PARAMS"
          ]
        },
        "unit_scale_source": {
          "$ref": "#/$defs/TokenV1"
        }
      }
    },
    "B555IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "target_pseudonym",
        "device_family",
        "schedule_program",
        "slot_index",
        "day_of_week",
        "time_identity",
        "operation_mode_context",
        "unit_scale_source"
      ],
      "properties": {
        "family": {
          "const": "B555"
        },
        "target_pseudonym": {
          "$ref": "#/$defs/TokenV1"
        },
        "device_family": {
          "$ref": "#/$defs/TokenV1"
        },
        "schedule_program": {
          "$ref": "#/$defs/TokenV1"
        },
        "slot_index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "day_of_week": {
          "enum": [
            "MONDAY",
            "TUESDAY",
            "WEDNESDAY",
            "THURSDAY",
            "FRIDAY",
            "SATURDAY",
            "SUNDAY"
          ]
        },
        "time_identity": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"
        },
        "operation_mode_context": {
          "$ref": "#/$defs/TokenV1"
        },
        "unit_scale_source": {
          "$ref": "#/$defs/TokenV1"
        }
      }
    },
    "EEBusPathV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "entity",
        "feature",
        "feature_path"
      ],
      "properties": {
        "service": {
          "$ref": "#/$defs/TokenV1"
        },
        "entity": {
          "$ref": "#/$defs/TokenV1"
        },
        "feature": {
          "$ref": "#/$defs/TokenV1"
        },
        "feature_path": {
          "type": "array",
          "minItems": 3,
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "selector"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "SERVICE",
                  "ENTITY",
                  "FEATURE",
                  "FIELD"
                ]
              },
              "selector": {
                "$ref": "#/$defs/TokenV1"
              }
            }
          }
        }
      }
    },
    "CloudRefV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "artifact_id",
        "evidence_id"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/TokenV1"
        },
        "artifact_id": {
          "$ref": "#/$defs/TokenV1"
        },
        "evidence_id": {
          "$ref": "#/$defs/TokenV1"
        }
      }
    },
    "NullableEBusIdentityV1": {
      "oneOf": [
        {
          "$ref": "#/$defs/B509IdentityV1"
        },
        {
          "$ref": "#/$defs/B524IdentityV1"
        },
        {
          "$ref": "#/$defs/B555IdentityV1"
        },
        {
          "type": "null"
        }
      ]
    },
    "ProvenanceV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_bundle_id",
        "native_evidence_refs",
        "ebus_source_id",
        "ebus_artifact_id",
        "ebus",
        "eebus_source_id",
        "eebus_artifact_id",
        "eebus",
        "cloud"
      ],
      "properties": {
        "source_bundle_id": {
          "type": "string",
          "pattern": "^sebv1:sha256:[0-9a-f]{64}$"
        },
        "native_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/EvidenceRefV1"
          }
        },
        "ebus_source_id": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "ebus_artifact_id": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "ebus": {
          "$ref": "#/$defs/NullableEBusIdentityV1"
        },
        "eebus_source_id": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "eebus_artifact_id": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "eebus": {
          "oneOf": [
            {
              "$ref": "#/$defs/EEBusPathV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "cloud": {
          "oneOf": [
            {
              "$ref": "#/$defs/CloudRefV1"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "ComparatorEvaluationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draft_id",
        "samples",
        "outcome"
      ],
      "properties": {
        "draft_id": {
          "const": "NUMERIC_WINDOW_V1_DRAFT"
        },
        "samples": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "offset_ns",
              "left_decimal",
              "right_decimal",
              "state"
            ],
            "properties": {
              "offset_ns": {
                "type": "integer",
                "minimum": 0
              },
              "left_decimal": {
                "oneOf": [
                  {
                    "$ref": "#/$defs/DecimalV1"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "right_decimal": {
                "oneOf": [
                  {
                    "$ref": "#/$defs/DecimalV1"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "state": {
                "enum": [
                  "PRESENT",
                  "MISSING",
                  "STALE"
                ]
              }
            }
          }
        },
        "outcome": {
          "enum": [
            "MATCH",
            "MISMATCH",
            "CONFLICT",
            "INDETERMINATE",
            "NOT_EVALUATED"
          ]
        }
      }
    },
    "FalsifierV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition_code",
        "expected_terminal_state",
        "description"
      ],
      "properties": {
        "condition_code": {
          "enum": [
            "VALUE_DIVERGES",
            "IDENTITY_CHANGES",
            "SIGNAL_DISAPPEARS",
            "ORDER_CHANGES",
            "PROVENANCE_BREAKS"
          ]
        },
        "expected_terminal_state": {
          "enum": [
            "NO_SIGNAL",
            "CLOUD_ONLY",
            "CONFLICT",
            "NOT_TESTED"
          ]
        },
        "description": {
          "$ref": "#/$defs/TokenV1"
        }
      }
    },
    "RetestTriggerV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_code",
        "required_source_kinds",
        "minimum_new_samples"
      ],
      "properties": {
        "trigger_code": {
          "enum": [
            "NEW_SYNCHRONIZED_BUNDLE",
            "SOURCE_RECOVERED",
            "IDENTITY_CONFIRMED",
            "COMPARATOR_REVISED"
          ]
        },
        "required_source_kinds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "CLOUD_APP",
              "EBUS",
              "EEBUS"
            ]
          }
        },
        "minimum_new_samples": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024
        }
      }
    },
    "FactV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "proposed_path",
        "draft_value",
        "draft_unit",
        "status",
        "terminal_negative_state",
        "confidence",
        "provenance",
        "comparator",
        "falsifier",
        "retest_trigger",
        "debug_only",
        "fact_hash"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^m7-candidate-[0-9]{4}$"
        },
        "proposed_path": {
          "type": "string",
          "pattern": "^/[a-z0-9_]+(?:/[a-z0-9_]+)*$",
          "maxLength": 512
        },
        "draft_value": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "draft_unit": {
          "$ref": "#/$defs/NullableTokenV1"
        },
        "status": {
          "enum": [
            "RAW_ONLY",
            "CANDIDATE",
            "CONFLICTED",
            "WITHHELD"
          ]
        },
        "terminal_negative_state": {
          "oneOf": [
            {
              "enum": [
                "NO_SIGNAL",
                "CLOUD_ONLY",
                "CONFLICT",
                "NOT_TESTED"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence": {
          "$ref": "#/$defs/ConfidenceV1"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceV1"
        },
        "comparator": {
          "$ref": "#/$defs/ComparatorEvaluationV1"
        },
        "falsifier": {
          "$ref": "#/$defs/FalsifierV1"
        },
        "retest_trigger": {
          "$ref": "#/$defs/RetestTriggerV1"
        },
        "debug_only": {
          "const": true
        },
        "fact_hash": {
          "$ref": "#/$defs/DigestV1"
        }
      }
    }
  }
}
