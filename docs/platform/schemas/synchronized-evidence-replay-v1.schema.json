{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:platform:synchronized-evidence-replay:v1",
  "title": "ReplayResultV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schema_version",
    "bundle_id",
    "raw_normalized_evidence",
    "captured_timestamps",
    "terminal_states",
    "redacted_hashes",
    "future_candidate_inputs"
  ],
  "properties": {
    "contract": {"const": "helianthus.platform.synchronized-evidence-replay.v1"},
    "schema_version": {"const": 1},
    "bundle_id": {"$ref": "#/$defs/BundleIdV1"},
    "raw_normalized_evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/RawNormalizedEvidenceRowV1"}
    },
    "captured_timestamps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/CapturedTimestampRowV1"}
    },
    "terminal_states": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/TerminalStateRowV1"}
    },
    "redacted_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/RedactedHashRowV1"}
    },
    "future_candidate_inputs": {
      "type": "array",
      "items": {"$ref": "#/$defs/FutureCandidateInputRowV1"}
    }
  },
  "$defs": {
    "SafeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "TimestampV1": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{0,8}[1-9])?Z$"
    },
    "DigestV1": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ArtifactIdV1": {
      "type": "string",
      "pattern": "^seav1:sha256:[0-9a-f]{64}$"
    },
    "BundleIdV1": {
      "type": "string",
      "pattern": "^sebv1:sha256:[0-9a-f]{64}$"
    },
    "RepositoryV1": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "maxLength": 256
    },
    "RepositoryPathV1": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-][A-Za-z0-9._-]*(/[A-Za-z0-9_-][A-Za-z0-9._-]*)*$",
      "maxLength": 1024
    },
    "GitCommitV1": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "SchemaDigestV1": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "EvidenceRefV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest_algorithm", "digest", "repository", "commit", "path"],
      "properties": {
        "kind": {"enum": ["CONTENT", "GIT_BLOB"]},
        "digest_algorithm": {"enum": ["SHA256_CONTENT_BYTES", "SHA256_GIT_BLOB_V1"]},
        "digest": {"$ref": "#/$defs/DigestV1"},
        "repository": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/RepositoryV1"}]},
        "commit": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/GitCommitV1"}]},
        "path": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/RepositoryPathV1"}]}
      }
    },
    "B509IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "target_pseudonym", "target_address", "target_product", "register_family", "register_id", "unit_scale_source", "evidence_role"],
      "properties": {
        "family": {"const": "B509"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "target_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "target_product": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "register_family": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "register_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "unit_scale_source": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "evidence_role": {"enum": ["AUTHORITATIVE", "MIRROR", "FALLBACK"]}
      }
    },
    "B524IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "target_pseudonym", "opcode", "GG", "II", "RR", "target_address", "source_address", "group_meaning", "instance_gate", "register_category", "unit_scale_source"],
      "properties": {
        "family": {"const": "B524"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "opcode": {"type": "integer", "minimum": 0, "maximum": 255},
        "GG": {"type": "integer", "minimum": 0, "maximum": 255},
        "II": {"type": "integer", "minimum": 0, "maximum": 255},
        "RR": {"type": "integer", "minimum": 0, "maximum": 65535},
        "target_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "source_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "group_meaning": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "instance_gate": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "register_category": {"enum": ["STATE", "CONFIG", "PARAMS"]},
        "unit_scale_source": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128}
      }
    },
    "B555IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "target_pseudonym", "device_family", "schedule_program", "slot_index", "day_of_week", "time_identity", "operation_mode_context", "unit_scale_source"],
      "properties": {
        "family": {"const": "B555"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "device_family": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "schedule_program": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "slot_index": {"type": "integer", "minimum": 0, "maximum": 255},
        "day_of_week": {"enum": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY"]},
        "time_identity": {"type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"},
        "operation_mode_context": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "unit_scale_source": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128}
      }
    },
    "SourceBindingV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_kind", "runtime_pseudonym", "operation_id", "operation_version", "request_scope", "snapshot_scope", "source_kind", "source_contract", "source_schema_version", "owner_repository", "owner_path", "owner_commit", "schema_sha256", "capture_window", "mask_tier", "auth_scope", "ebus_identity"],
      "properties": {
        "runtime_kind": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]},
        "runtime_pseudonym": {"type": "string", "pattern": "^runtime-[0-9a-f]{32}$"},
        "operation_id": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "operation_version": {"type": "string", "pattern": "^git:[0-9a-f]{40}$"},
        "request_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase", "source_kind", "operation_scope"],
          "properties": {
            "phase": {"enum": ["pre", "action", "post"]},
            "source_kind": {"enum": ["EBUS", "EEBUS", "CLOUD_APP"]},
            "operation_scope": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128}
          }
        },
        "snapshot_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "selector"],
          "properties": {
            "mode": {"enum": ["SNAPSHOT", "LIVE_READ", "PRECAPTURED"]},
            "selector": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128}
          }
        },
        "source_kind": {"enum": ["EBUS_B509", "EBUS_B524", "EBUS_B555", "EEBUS", "CLOUD_APP"]},
        "source_contract": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128},
        "source_schema_version": {"$ref": "#/$defs/SafeInteger"},
        "owner_repository": {"$ref": "#/$defs/RepositoryV1"},
        "owner_path": {"$ref": "#/$defs/RepositoryPathV1"},
        "owner_commit": {"$ref": "#/$defs/GitCommitV1"},
        "schema_sha256": {"$ref": "#/$defs/SchemaDigestV1"},
        "capture_window": {"type": "object"},
        "mask_tier": {"const": "redacted"},
        "auth_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["authority", "permissions"],
          "properties": {
            "authority": {"const": "effective"},
            "permissions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[ -~]+$", "maxLength": 128}}
          }
        },
        "ebus_identity": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/B509IdentityV1"},
            {"$ref": "#/$defs/B524IdentityV1"},
            {"$ref": "#/$defs/B555IdentityV1"}
          ]
        }
      }
    },
    "RawNormalizedEvidenceRowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "source_binding", "source_observed_at", "normalized_evidence"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/ArtifactIdV1"},
        "source_binding": {"$ref": "#/$defs/SourceBindingV1"},
        "source_observed_at": {"$ref": "#/$defs/TimestampV1"},
        "normalized_evidence": {}
      }
    },
    "CapturedTimestampRowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_kind", "source_id", "artifact_id", "source_observed_at", "recorder_observed_at", "recorder_offset_ns"],
      "properties": {
        "event_kind": {"enum": ["ACTION_MARKER", "SOURCE_ACQUISITION_START", "SOURCE_ACQUISITION_END", "ARTIFACT_INGESTION"]},
        "source_id": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^(ebus|eebus|cloud)-[0-9a-f]{32}$"}]},
        "artifact_id": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ArtifactIdV1"}]},
        "source_observed_at": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/TimestampV1"}]},
        "recorder_observed_at": {"$ref": "#/$defs/TimestampV1"},
        "recorder_offset_ns": {"$ref": "#/$defs/SafeInteger"}
      }
    },
    "TerminalStateRowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "phase", "state", "error_category"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^(ebus|eebus|cloud)-[0-9a-f]{32}$"},
        "phase": {"enum": ["pre", "action", "post"]},
        "state": {"enum": ["PRESENT", "WITHHELD", "NOT_TESTED", "UNAVAILABLE"]},
        "error_category": {
          "oneOf": [
            {"type": "null"},
            {"enum": ["POLICY_WITHHELD", "AUTHORIZATION_DENIED", "REDACTION_FAILED", "EXACT_IDENTITY_MISSING", "NOT_SELECTED", "BUDGET_EXHAUSTED", "BACKEND_UNAVAILABLE", "TIMEOUT", "ACQUISITION_FAILED"]}
          ]
        }
      }
    },
    "RedactedHashRowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "artifact_id", "digest"],
      "properties": {
        "kind": {"enum": ["ARTIFACT", "BUNDLE"]},
        "artifact_id": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ArtifactIdV1"}]},
        "digest": {"$ref": "#/$defs/DigestV1"}
      }
    },
    "FutureCandidateInputRowV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "source_id", "source_binding", "evidence_refs", "redacted_hash"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/ArtifactIdV1"},
        "source_id": {"type": "string", "pattern": "^(ebus|eebus|cloud)-[0-9a-f]{32}$"},
        "source_binding": {"$ref": "#/$defs/SourceBindingV1"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/EvidenceRefV1"}},
        "redacted_hash": {"$ref": "#/$defs/DigestV1"}
      }
    }
  }
}
