{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:source:ebus:b509:evidence:v1",
  "title": "Closed B509 normalized evidence V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "schema_version", "source_observed_at", "identity", "observations"],
  "properties": {
    "contract": {"const": "helianthus.ebus.b509.evidence.v1"},
    "schema_version": {"const": 1},
    "source_observed_at": {"$ref": "#/$defs/TimestampV1"},
    "identity": {"$ref": "#/$defs/B509IdentityV1"},
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {"$ref": "#/$defs/ObservationV1"}
    }
  },
  "$defs": {
    "TimestampV1": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]{1,8}[1-9])?Z$"
    },
    "AsciiTokenV1": {
      "type": "string",
      "pattern": "^[ -~]+$",
      "maxLength": 128
    },
    "B509IdentityV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "target_pseudonym", "target_address", "target_product", "register_family", "register_id", "unit_scale_source", "evidence_role"],
      "properties": {
        "family": {"const": "B509"},
        "target_pseudonym": {"type": "string", "pattern": "^target-[0-9a-f]{32}$"},
        "target_address": {"type": "integer", "minimum": 0, "maximum": 255},
        "target_product": {"$ref": "#/$defs/AsciiTokenV1"},
        "register_family": {"$ref": "#/$defs/AsciiTokenV1"},
        "register_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "unit_scale_source": {"$ref": "#/$defs/AsciiTokenV1"},
        "evidence_role": {"enum": ["AUTHORITATIVE", "MIRROR", "FALLBACK"]}
      }
    },
    "ObservationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["register_id", "value", "unit", "quality"],
      "properties": {
        "register_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "value": {"$ref": "#/$defs/AsciiTokenV1"},
        "unit": {"$ref": "#/$defs/AsciiTokenV1"},
        "quality": {"enum": ["OBSERVED", "STALE"]}
      }
    }
  }
}
