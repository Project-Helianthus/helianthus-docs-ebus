{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helianthus:platform:draft-candidate-fact-replay:v1",
  "title": "Helianthus deterministic M7 candidate fact replay V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schema_version",
    "replay_id",
    "replay_hash",
    "graph_id",
    "graph_hash",
    "registry_digest",
    "source_bundle",
    "results"
  ],
  "properties": {
    "contract": {
      "const": "helianthus.platform.draft-candidate-fact-replay.v1"
    },
    "schema_version": {
      "const": 1
    },
    "replay_id": {
      "type": "string",
      "pattern": "^dcfrv1:sha256:[0-9a-f]{64}$"
    },
    "replay_hash": {
      "$ref": "#/$defs/DigestV1"
    },
    "graph_id": {
      "type": "string",
      "pattern": "^dcfgv1:sha256:[0-9a-f]{64}$"
    },
    "graph_hash": {
      "$ref": "#/$defs/DigestV1"
    },
    "registry_digest": {
      "$ref": "#/$defs/DigestV1"
    },
    "source_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "bundle_hash",
        "replay_hash"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "pattern": "^sebv1:sha256:[0-9a-f]{64}$"
        },
        "bundle_hash": {
          "$ref": "#/$defs/DigestV1"
        },
        "replay_hash": {
          "$ref": "#/$defs/DigestV1"
        }
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/ResultV1"
      }
    }
  },
  "$defs": {
    "DigestV1": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ResultV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "proposed_path",
        "status",
        "terminal_negative_state",
        "confidence",
        "comparator_outcome",
        "fact_hash",
        "native_evidence_digests"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^m7-candidate-[0-9]{4}$"
        },
        "proposed_path": {
          "type": "string"
        },
        "status": {
          "enum": [
            "RAW_ONLY",
            "CANDIDATE",
            "CONFLICTED",
            "WITHHELD"
          ]
        },
        "terminal_negative_state": {
          "oneOf": [
            {
              "enum": [
                "NO_SIGNAL",
                "CLOUD_ONLY",
                "CONFLICT",
                "NOT_TESTED"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level",
            "basis",
            "score_milli"
          ],
          "properties": {
            "level": {
              "enum": [
                "LOW",
                "MEDIUM",
                "HIGH"
              ]
            },
            "basis": {
              "enum": [
                "OBSERVED",
                "INFERRED",
                "INSUFFICIENT"
              ]
            },
            "score_milli": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000
            }
          }
        },
        "comparator_outcome": {
          "enum": [
            "MATCH",
            "MISMATCH",
            "CONFLICT",
            "INDETERMINATE",
            "NOT_EVALUATED"
          ]
        },
        "fact_hash": {
          "$ref": "#/$defs/DigestV1"
        },
        "native_evidence_digests": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/DigestV1"
          }
        }
      }
    }
  }
}
